  <!-- Step 3: Device posture -->
  <rect x="22" y="278" width="636" height="96" rx="12" fill="none" stroke="#0F6E56" stroke-width="1" stroke-dasharray="5 3" opacity="0.5" style="fill:none;stroke:rgb(15, 110, 86);color:rgb(255, 255, 255);stroke-width:1px;stroke-dasharray:5px, 3px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.5;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
